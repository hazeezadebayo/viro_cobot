<?xml version="1.0"?>
<robot xmlns:xacro="http://wiki.ros.org/xacro">

    <xacro:macro name="cobot_gripper" params="parent">

        <!-- Gripper Base -->
        <joint name="gripper_base_joint" type="fixed">
            <parent link="${parent}"/>
            <child link="gripper_base"/>
            <!-- Offset to the tool flange face (standard UR5 d6 = 82.3mm) -->
            <origin xyz="0 0.0823 0" rpy="0 0 0"/>
        </joint>

        <link name="gripper_base">
            <visual>
                <!-- Thinner 2.5mm base plate -->
                <origin xyz="0 0.00125 0" rpy="1.5708 0 0"/>
                <geometry>
                    <cylinder radius="0.04" length="0.0025"/>
                </geometry>
                <material name="gray"/>
            </visual>
            <visual>
                <!-- Compact 40mm housing (reduced extrusion) -->
                <origin xyz="0 0.0225 0" rpy="0 0 0"/>
                <geometry>
                    <box size="0.08 0.04 0.04"/>
                </geometry>
                <material name="gray"/>
            </visual>
            <collision>
                <origin xyz="0 0.02125 0" rpy="0 0 0"/>
                <geometry>
                    <box size="0.08 0.0425 0.04"/>
                </geometry>
            </collision>
            <inertial>
                <mass value="0.1"/>
                <origin xyz="0 0.02 0" rpy="0 0 0"/>
                <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
            </inertial>
        </link>

        <!-- Left Finger (Active) -->
        <joint name="gripper_finger_left_joint" type="revolute">
            <parent link="gripper_base"/>
            <child link="gripper_finger_left"/>
            <!-- 2.5mm base + 40mm housing = 42.5mm -->
            <origin xyz="0 0.0425 0.03" rpy="0 0 0"/>
            <axis xyz="1 0 0"/>
            <limit lower="0.0" upper="1.0" effort="10.0" velocity="1.0"/>
            <dynamics damping="0.1" friction="0.1"/>
        </joint>

        <link name="gripper_finger_left">
            <visual>
                <origin xyz="0 0.04 0" rpy="0 0 0"/>
                <geometry>
                    <box size="0.01 0.08 0.01"/>
                </geometry>
                <material name="black"/>
            </visual>
            <visual>
                <origin xyz="0 0.08 -0.01" rpy="0 0 0"/>
                <geometry>
                    <box size="0.01 0.01 0.03"/>
                </geometry>
                <material name="black"/>
            </visual>
            <collision>
                <origin xyz="0 0.04 0" rpy="0 0 0"/>
                <geometry>
                    <box size="0.01 0.08 0.01"/>
                </geometry>
            </collision>
            <inertial>
                <mass value="0.02"/>
                <origin xyz="0 0.04 0" rpy="0 0 0"/>
                <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.000001"/>
            </inertial>
        </link>

        <!-- Right Finger (Mimic) -->
        <joint name="gripper_finger_right_joint" type="revolute">
            <parent link="gripper_base"/>
            <child link="gripper_finger_right"/>
            <origin xyz="0 0.0425 -0.03" rpy="0 0 0"/>
            <axis xyz="-1 0 0"/>
            <mimic joint="gripper_finger_left_joint" multiplier="1.0" offset="0.0"/>
            <limit lower="0.0" upper="1.0" effort="10.0" velocity="1.0"/>
            <dynamics damping="0.1" friction="0.1"/>
        </joint>

        <link name="gripper_finger_right">
            <visual>
                <origin xyz="0 0.04 0" rpy="0 0 0"/>
                <geometry>
                    <box size="0.01 0.08 0.01"/>
                </geometry>
                <material name="black"/>
            </visual>
            <visual>
                <origin xyz="0 0.08 0.01" rpy="0 0 0"/>
                <geometry>
                    <box size="0.01 0.01 0.03"/>
                </geometry>
                <material name="black"/>
            </visual>
            <collision>
                <origin xyz="0 0.04 0" rpy="0 0 0"/>
                <geometry>
                    <box size="0.01 0.08 0.01"/>
                </geometry>
            </collision>
            <inertial>
                <mass value="0.02"/>
                <origin xyz="0 0.04 0" rpy="0 0 0"/>
                <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.000001"/>
            </inertial>
        </link>

        <!-- TCP (Tool Center Point) -->
        <joint name="gripper_tcp_joint" type="fixed">
            <parent link="gripper_base"/>
            <child link="gripper_tcp"/>
            <!-- 42.5mm + 80mm jaws = 122.5mm -->
            <origin xyz="0 0.1225 0" rpy="0 0 0"/>
        </joint>
        <link name="gripper_tcp"/>

        <!-- Phantom joint to satisfy Ignition Gazebo's _mimic suffixing bug -->
        <joint name="gripper_finger_right_joint_mimic" type="fixed">
            <parent link="gripper_base" />
            <child link="phantom_mimic_link" />
        </joint>
        <link name="phantom_mimic_link"/>

    </xacro:macro>

</robot>
