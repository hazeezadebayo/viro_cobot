<?xml version="1.0"?>

<robot xmlns:xacro="http://wiki.ros.org/xacro">

    <xacro:macro name="cobot">

        <!-- material and colours -->

        <material name="black">
            <color rgba="0.2 0.2 0.2 1.0" />
        </material>
        <material name="gray">
            <color rgba="0.7 0.7 0.7 1.0" />
        </material>
        <material name="blue">
            <color rgba="0.1 0.5 0.7 1.0" />
        </material>

        <!-- main links and joints -->

        <link name="base_link">
            <visual>
            <geometry>
                <mesh filename="package://cobot_description/meshes/ur5/base.stl"/>
            </geometry>
            <material name="LightGrey">
                <color rgba="0.7 0.7 0.7 1.0"/>
            </material>
            </visual>
            <collision>
            <geometry>
                <mesh filename="package://cobot_description/meshes/ur5/base.stl"/>
            </geometry>
            </collision>
            <inertial>
            <mass value="4.0"/>
            <origin rpy="0 0 0" xyz="0.0 0.0 0.0"/>
            <inertia ixx="0.00443333156" ixy="0.0" ixz="0.0" iyy="0.00443333156" iyz="0.0" izz="0.0072"/>
            </inertial>
        </link>





        <joint name="joint_1" type="revolute">
            <parent link="base_link"/>
            <child link="link_1"/>
            <origin rpy="0.0 0.0 0.0" xyz="0.0 0.0 0.089159"/>
            <axis xyz="0 0 1"/>
            <limit effort="150.0" lower="-6.28318530718" upper="6.28318530718" velocity="3.15"/>
            <dynamics damping="0.5" friction="0.1"/>
        </joint>

        <link name="link_1">
            <visual>
            <geometry>
                <mesh filename="package://cobot_description/meshes/ur5/shoulder.stl"/>
            </geometry>
            <material name="LightGrey">
                <color rgba="0.7 0.7 0.7 1.0"/>
            </material>
            </visual>
            <collision>
            <geometry>
                <mesh filename="package://cobot_description/meshes/ur5/shoulder.stl"/>
            </geometry>
            </collision>
            <inertial>
            <mass value="3.7"/>
            <origin rpy="0 0 0" xyz="0.0 0.0 0.0"/>
            <inertia ixx="0.010267495893" ixy="0.0" ixz="0.0" iyy="0.010267495893" iyz="0.0" izz="0.00666"/>
            </inertial>
        </link>




        <joint name="joint_2" type="revolute">
            <parent link="link_1"/>
            <child link="link_2"/>
            <origin rpy="0.0 1.57079632679 0.0" xyz="0.0 0.13585 0.0"/>
            <axis xyz="0 1 0"/>
            <limit effort="150.0" lower="-6.28318530718" upper="6.28318530718" velocity="3.15"/>
            <dynamics damping="0.5" friction="0.1"/>
        </joint>

        <link name="link_2">
            <visual>
            <geometry>
                <mesh filename="package://cobot_description/meshes/ur5/upperarm.stl"/>
            </geometry>
            <material name="LightGrey">
                <color rgba="0.7 0.7 0.7 1.0"/>
            </material>
            </visual>
            <collision>
            <geometry>
                <mesh filename="package://cobot_description/meshes/ur5/upperarm.stl"/>
            </geometry>
            </collision>
            <inertial>
            <mass value="8.393"/>
            <origin rpy="0 0 0" xyz="0.0 0.0 0.28"/>
            <inertia ixx="0.22689067591" ixy="0.0" ixz="0.0" iyy="0.22689067591" iyz="0.0" izz="0.0151074"/>
            </inertial>
        </link>




        <joint name="joint_3" type="revolute">
            <parent link="link_2"/>
            <child link="link_3"/>
            <origin rpy="0.0 0.0 0.0" xyz="0.0 -0.1197 0.425"/>
            <axis xyz="0 1 0"/>
            <limit effort="150.0" lower="-3.14159265359" upper="3.14159265359" velocity="3.15"/>
            <dynamics damping="0.5" friction="0.1"/>
        </joint>

        <link name="link_3">
            <visual>
            <geometry>
                <mesh filename="package://cobot_description/meshes/ur5/forearm.stl"/>
            </geometry>
            <material name="LightGrey">
                <color rgba="0.7 0.7 0.7 1.0"/>
            </material>
            </visual>
            <collision>
            <geometry>
                <mesh filename="package://cobot_description/meshes/ur5/forearm.stl"/>
            </geometry>
            </collision>
            <inertial>
            <mass value="2.275"/>
            <origin rpy="0 0 0" xyz="0.0 0.0 0.25"/>
            <inertia ixx="0.049443313556" ixy="0.0" ixz="0.0" iyy="0.049443313556" iyz="0.0" izz="0.004095"/>
            </inertial>
        </link>




        <joint name="joint_4" type="revolute">
            <parent link="link_3"/>
            <child link="link_4"/>
            <origin rpy="0.0 1.57079632679 0.0" xyz="0.0 0.0 0.39225"/>
            <axis xyz="0 1 0"/>
            <limit effort="28.0" lower="-6.28318530718" upper="6.28318530718" velocity="3.2"/>
            <dynamics damping="0.5" friction="0.1"/>
        </joint>

        <link name="link_4">
            <visual>
            <geometry>
                <mesh filename="package://cobot_description/meshes/ur5/wrist1.stl"/>
            </geometry>
            <material name="LightGrey">
                <color rgba="0.7 0.7 0.7 1.0"/>
            </material>
            </visual>
            <collision>
            <geometry>
                <mesh filename="package://cobot_description/meshes/ur5/wrist1.stl"/>
            </geometry>
            </collision>
            <inertial>
            <mass value="1.219"/>
            <origin rpy="0 0 0" xyz="0.0 0.0 0.0"/>
            <inertia ixx="0.111172755531" ixy="0.0" ixz="0.0" iyy="0.111172755531" iyz="0.0" izz="0.21942"/>
            </inertial>
        </link>





        <joint name="joint_5" type="revolute">
            <parent link="link_4"/>
            <child link="link_5"/>
            <origin rpy="0.0 0.0 0.0" xyz="0.0 0.093 0.0"/>
            <axis xyz="0 0 1"/>
            <limit effort="28.0" lower="-6.28318530718" upper="6.28318530718" velocity="3.2"/>
            <dynamics damping="0.5" friction="0.1"/>
        </joint>

        <link name="link_5">
            <visual>
            <geometry>
                <mesh filename="package://cobot_description/meshes/ur5/wrist2.stl"/>
            </geometry>
            <material name="LightGrey">
                <color rgba="0.7 0.7 0.7 1.0"/>
            </material>
            </visual>
            <collision>
            <geometry>
                <mesh filename="package://cobot_description/meshes/ur5/wrist2.stl"/>
            </geometry>
            </collision>
            <inertial>
            <mass value="1.219"/>
            <origin rpy="0 0 0" xyz="0.0 0.0 0.0"/>
            <inertia ixx="0.111172755531" ixy="0.0" ixz="0.0" iyy="0.111172755531" iyz="0.0" izz="0.21942"/>
            </inertial>
        </link>





        <joint name="joint_6" type="revolute">
            <parent link="link_5"/>
            <child link="link_6"/>
            <origin rpy="0.0 0.0 0.0" xyz="0.0 0.0 0.09465"/>
            <axis xyz="0 1 0"/>
            <limit effort="28.0" lower="-6.28318530718" upper="6.28318530718" velocity="3.2"/>
            <dynamics damping="0.5" friction="0.1"/>
        </joint>

        <link name="link_6">
            <visual>
            <geometry>
                <mesh filename="package://cobot_description/meshes/ur5/wrist3.stl"/>
            </geometry>
            <material name="LightGrey">
                <color rgba="0.7 0.7 0.7 1.0"/>
            </material>
            </visual>
            <collision>
            <geometry>
                <mesh filename="package://cobot_description/meshes/ur5/wrist3.stl"/>
            </geometry>
            </collision>
            <inertial>
            <mass value="0.1879"/>
            <origin rpy="0 0 0" xyz="0.0 0.0 0.0"/>
            <inertia ixx="0.0171364731454" ixy="0.0" ixz="0.0" iyy="0.0171364731454" iyz="0.0" izz="0.033822"/>
            </inertial>
        </link>



        <!-- Legacy TCP (Commented out to prevent conflict with gripper_tcp) -->
        <!--
        <joint name="eef_tcp" type="fixed">
            <parent link="link_6" />
            <child link="eef_tcp_link" />
            <origin rpy="0.0 0.0 0.0" xyz="0.0 0.1 0.0"/>
        </joint>
        <link name="eef_tcp_link" />
        -->

    </xacro:macro>

</robot>